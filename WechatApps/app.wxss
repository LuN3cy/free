page {
  background-color: #f8fafc;
  font-family: 'Product Sans', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  color: #0f172a;
  box-sizing: border-box;
}
@media (prefers-color-scheme: dark) {
  page {
    background-color: #0b0f19;
    color: #f1f5f9;
  }
}
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
  min-height: 100vh;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #0f172a;
  display: block;
}
@media (prefers-color-scheme: dark) {
  .title { color: #f1f5f9; }
}
.subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 10rpx;
  display: block;
}
@media (prefers-color-scheme: dark) {
  .subtitle { color: #94a3b8; }
}

/* 完美复刻 Tailwind 的玻璃拟态 (Glassmorphism) */
.card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid #e2e8f0;
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
@media (prefers-color-scheme: dark) {
  .card {
    background: rgba(30, 41, 59, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.2);
  }
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  color: #1e293b;
  display: flex;
  align-items: center;
}
@media (prefers-color-scheme: dark) {
  .card-title { color: #cbd5e1; }
}
.card-title::before {
  content: '';
  display: inline-block;
  width: 16rpx;
  height: 32rpx;
  background: #FF8A00;
  border-radius: 8rpx;
  margin-right: 16rpx;
}
.balls {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}
.ball {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  border: 1px solid;
}
.ball.red {
  background: linear-gradient(135deg, #f87171, #dc2626);
  border-color: rgba(248, 113, 113, 0.5);
  box-shadow: 0 4rpx 10px rgba(239,68,68,0.2);
}
@media (prefers-color-scheme: dark) {
  .ball.red {
    background: linear-gradient(135deg, #ef4444, #b91c1c);
    box-shadow: inset 0 0 20px rgba(255,255,255,0.05), 0 0 15px rgba(239,68,68,0.3);
  }
}
.ball.blue {
  background: linear-gradient(135deg, #60a5fa, #2563eb);
  border-color: rgba(96, 165, 250, 0.5);
  box-shadow: 0 4rpx 10px rgba(59,130,246,0.2);
}
@media (prefers-color-scheme: dark) {
  .ball.blue {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    box-shadow: inset 0 0 20px rgba(255,255,255,0.05), 0 0 15px rgba(59,130,246,0.3);
  }
}
.plus {
  font-size: 40rpx;
  color: #64748b;
  margin: 0 10rpx;
}
@media (prefers-color-scheme: dark) {
  .plus { color: #475569; }
}