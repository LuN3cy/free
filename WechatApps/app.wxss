page {
  background-color: #0b0f19;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  color: #f1f5f9;
  box-sizing: border-box;
}
.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
  min-height: 100vh;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
}
.subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  display: block;
}
.card {
  background: rgba(30, 41, 59, 0.4);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 48rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  color: #cbd5e1;
  display: flex;
  align-items: center;
}
.card-title::before {
  content: '';
  display: inline-block;
  width: 16rpx;
  height: 32rpx;
  background: #FF8A00;
  border-radius: 8rpx;
  margin-right: 16rpx;
}
.balls {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}
.ball {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  border: 1px solid;
}
.ball.red {
  background: linear-gradient(135deg, #ef4444, #b91c1c);
  border-color: rgba(248, 113, 113, 0.5);
  box-shadow: inset 0 0 20px rgba(255,255,255,0.05), 0 0 15px rgba(239,68,68,0.3);
}
.ball.blue {
  background: linear-gradient(135deg, #3b82f6, #1d4ed8);
  border-color: rgba(96, 165, 250, 0.5);
  box-shadow: inset 0 0 20px rgba(255,255,255,0.05), 0 0 15px rgba(59,130,246,0.3);
}
.plus {
  font-size: 40rpx;
  color: #475569;
  margin: 0 10rpx;
}