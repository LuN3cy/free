.sync-btn {
  background: #FF8A00;
  color: white;
  font-size: 26rpx;
  font-weight: bold;
  margin: 0;
  padding: 0 30rpx;
  border-radius: 40rpx;
  height: 64rpx;
  line-height: 64rpx;
}
.sync-btn-hover {
  background: #E67A00;
}
.date {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.05);
  padding: 16rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}
.stat-row {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
  background: rgba(0, 0, 0, 0.2);
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
}
.highlight {
  color: #FF8A00;
  font-size: 60rpx;
  font-weight: bold;
  margin-top: 10rpx;
}
.stat-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 20rpx;
  background: rgba(0, 0, 0, 0.1);
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  line-height: 1.5;
}
.empty {
  text-align: center;
  color: #64748b;
  padding: 60rpx 0;
}